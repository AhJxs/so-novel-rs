# Docker 构建上下文忽略 —— COPY . . 不会把这些发给 daemon
# 大幅缩短构建上下文上传 + 避免 cache 失效

# 编译产物（本地 cargo build 出来的）
target/

# 编译缓存
**/*.rs.bk

# VCS / IDE
.git/
.gitignore
.gitattributes
.githooks/

# Claude / 工具配置（不进镜像）
.claude/
.codegraph/

# 项目级临时文件
screenshots/
*.log
*.tmp

# OS 杂项
.DS_Store
Thumbs.db

# CI 配置（不参与运行时）
.github/

# 本地 docs build 输出（如果有）
docs/_build/

# Rust 工具链版本锁（避免 cargo 误读）
rust-toolchain.toml
rust-toolchain

# 文档 / changelog（这些不进二进制）
docs/
*.md
LICENSE*
DISCLAIMER*
README*
CLAUDE.md

# 自己的 docker artifacts（防递归）
Dockerfile
.dockerignore
